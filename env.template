SERVER_HOST=0.0.0.0
SERVER_PORT=8080
PORT=8080

FREE_ACCOUNTS=true
FREE_ACCOUNTS_NUM=1024
Authorization=

TLS_CERT=
TLS_KEY=
PROXY_URL=
http_proxy=

# 转发代理（可选，给 backend-api / files 端点单独配置）
API_REVERSE_PROXY=
FILES_REVERSE_PROXY=

# 自定义 BASE_URL（默认 https://chatgpt.com/backend-api）
BASE_URL=

# 流式响应开关；设为 "false" 强制返回完整响应
STREAM_MODE=true

# 是否在请求中保留历史上下文；设为 "true" 启用
ENABLE_HISTORY=false
